{:paths ["src" "test"]
 :deps  {org.clojure/clojure          {:mvn/version "1.12.0"}
         org.clojure/clojurescript    {:mvn/version "1.11.132"}
         thheller/shadow-cljs         {:mvn/version "2.28.18"}
         com.github.avanelsas/baredom {:mvn/version "3.1.0"}
         ;; test.check is required only by property tests under
         ;; test/bareforge/**/*_property_test.cljs. Closure Advanced
         ;; doesn't include namespaces no production code requires,
         ;; so the release artefact is unaffected.
         org.clojure/test.check       {:mvn/version "1.1.1"}}

 :aliases
 ;; Scaffolder for onboarding a new BareDOM component into Bareforge.
 ;; Reads the BareDOM jar off the classpath, extracts observed
 ;; attributes, and edits public_api.cljs / augment.cljs /
 ;; categories.cljs via rewrite-clj. See scripts/scaffold_component.clj
 ;; and CLAUDE.md for the user-facing recipe. Dev-only — rewrite-clj
 ;; and tools.reader never ship in the app build.
 {:scaffold
  {:extra-paths ["scripts" "src"]
   :extra-deps  {rewrite-clj/rewrite-clj {:mvn/version "1.1.49"}}
   :exec-fn     scaffold-component/scaffold!}

  ;; Scaffold a new export plugin (target directory + skeleton
  ;; plugin.cljs with a pre-filled manifest). See
  ;; scripts/new_export.clj and docs/plugins.md for the user-facing
  ;; recipe.
  ;;
  ;;   clojure -X:new-export :id :react :label "React"
  ;;   clojure -X:new-export :id :svelte :label "Svelte" :order 50 :dry-run true
  :new-export
  {:extra-paths ["scripts"]
   :exec-fn     new-export/-main}

  ;; Editor-connected REPL middleware. shadow-cljs reads this alias
  ;; via shadow-cljs.edn's `:deps {:aliases [:nrepl]}`, so a plain
  ;; `npx shadow-cljs watch app` already exposes a CIDER-aware nREPL
  ;; on the port pinned in shadow-cljs.edn. See docs/repl.md.
  :nrepl
  {:extra-deps {nrepl/nrepl       {:mvn/version "1.3.0"}
                cider/cider-nrepl {:mvn/version "0.50.2"}}}

  ;; Release-cut helper. Promotes CHANGELOG.md's [Unreleased] block,
  ;; bumps package.json, verifies BareDOM lockstep (deps.edn ↔
  ;; meta/versions.cljs), and runs the four PR-readiness gates.
  ;; Tagging and pushing stay manual. See scripts/release.clj.
  ;;
  ;;   clojure -X:release :bump :patch                     ; preview
  ;;   clojure -X:release :bump :minor :confirm true       ; apply
  :release
  {:extra-paths ["scripts"]
   :exec-fn     release/-main}}}
