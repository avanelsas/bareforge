{:indents
 ;; clojure.test forms — body indented 2 spaces, not aligned under
 ;; the form name (which is what cljfmt's "function call" default
 ;; would do). Matches what every Clojure test file looks like.
 {deftest      [[:block 1]]
  testing      [[:block 1]]
  use-fixtures [[:block 1]]
  are          [[:block 2]]}

 :remove-surrounding-whitespace?  true
 :remove-trailing-whitespace?     true
 :insert-missing-whitespace?      true
 :remove-consecutive-blank-lines? true}
